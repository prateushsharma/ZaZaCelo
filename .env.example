# ─── Celo ────────────────────────────────────────────────────────────────────
CELO_RPC=https://forno.celo.org
CELO_WS_RPC=wss://forno.celo.org/ws
CELO_CHAIN_ID=42220
CELO_ALFAJORES_RPC=https://alfajores-forno.celo-testnet.org
CELO_ALFAJORES_WS_RPC=wss://alfajores-forno.celo-testnet.org/ws
CELO_ALFAJORES_CHAIN_ID=44787

# Contract addresses (populated after Module 1 deploy)
REGISTRY_ADDRESS=0x
ESCROW_ADDRESS=0x
STAKE_ADDRESS=0x

# Wallet
PRIVATE_KEY=0x
PAYMENT_WALLET=0x

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://agentmesh:secret@localhost:5432/agentmesh
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300

# ─── Queue ───────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=agentmesh

# ─── AI / Embeddings ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Storage ─────────────────────────────────────────────────────────────────
IPFS_GATEWAY=https://gateway.pinata.cloud
PINATA_JWT=

# ─── Services ────────────────────────────────────────────────────────────────
SEARCH_API_PORT=3001
MESSAGING_NODE_PORT=9000
DASHBOARD_PORT=5173

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agent-mesh