{
  "name": "@agentmesh/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:ci": "forge test --profile ci -vvv",
    "test:gas": "forge test --gas-report",
    "coverage": "forge coverage",
    "deploy:alfajores": "forge script script/Deploy.s.sol --rpc-url alfajores --broadcast --verify",
    "deploy:celo": "forge script script/Deploy.s.sol --rpc-url celo --broadcast --verify",
    "lint": "solhint 'src/**/*.sol'",
    "clean": "forge clean"
  },
  "devDependencies": {
    "solhint": "^4.5.4"
  }
}